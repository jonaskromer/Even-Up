generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String        @id
  email             String        @unique
  name              String
  preferredCurrency String        @default("EUR")
  defaultMarkupRate Float         @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  memberships       GroupMember[]
  paidExpenses      Expense[]     @relation("PaidBy")
  settlementsFrom   Settlement[]  @relation("SettlementFrom")
  settlementsTo     Settlement[]  @relation("SettlementTo")
  createdInvites       GroupInvite[]
  activities           Activity[]
  joinRequestsReceived GroupJoinRequest[] @relation("JoinRequestInvitee")
  joinRequestsSent     GroupJoinRequest[] @relation("JoinRequestInviter")
}

model Group {
  id          String        @id @default(cuid())
  name        String
  currency    String        @default("EUR")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  invites     GroupInvite[]
  activities  Activity[]
  joinRequests GroupJoinRequest[]
}

model GroupMember {
  groupId String
  userId  String
  role    String @default("member")
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

model Expense {
  id                  String         @id @default(cuid())
  groupId             String
  description         String
  amountCents         Int
  originalAmountCents Int            @default(0)
  originalCurrency    String         @default("EUR")
  appliedMarkupRate   Float          @default(0)
  paidByUserId        String
  date                DateTime
  splitMode           String         @default("equal")
  receiptStoreName    String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  group               Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy              User           @relation("PaidBy", fields: [paidByUserId], references: [id])
  splits              ExpenseSplit[]
  lineItems           ReceiptLineItem[]
}

model ExpenseSplit {
  expenseId String
  userId    String
  owedCents Int
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@id([expenseId, userId])
}

model Settlement {
  id          String   @id @default(cuid())
  groupId     String
  fromUserId  String
  toUserId    String
  amountCents Int
  date        DateTime
  note        String?
  createdAt   DateTime @default(now())
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUser    User     @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser      User     @relation("SettlementTo", fields: [toUserId], references: [id])
}

model Activity {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  type      String
  data      Json
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model GroupInvite {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  groupId   String
  createdBy String
  expiresAt DateTime
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator   User     @relation(fields: [createdBy], references: [id])
}

model GroupJoinRequest {
  id              String    @id @default(cuid())
  groupId         String
  invitedUserId   String
  invitedByUserId String
  status          String    @default("pending") // pending | accepted | declined
  createdAt       DateTime  @default(now())
  respondedAt     DateTime?
  group           Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedUser     User      @relation("JoinRequestInvitee", fields: [invitedUserId], references: [id])
  invitedBy       User      @relation("JoinRequestInviter", fields: [invitedByUserId], references: [id])

  @@index([invitedUserId, status])
  @@index([groupId, status])
}

model ReceiptLineItem {
  id          String   @id @default(cuid())
  expenseId   String
  name        String
  quantity    Float    @default(1)
  priceCents  Int
  sortOrder   Int      @default(0)
  excluded    Boolean  @default(false)
  splitMode   String   @default("shares") // 'equal' | 'exact' | 'percent' | 'shares'
  expense     Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  assignments ReceiptLineItemAssignment[]

  @@index([expenseId])
}

model ReceiptLineItemAssignment {
  lineItemId  String
  userId      String
  shareWeight Int             @default(1) // used when the item's splitMode is 'shares'
  exactCents  Int? // used when the item's splitMode is 'exact'
  percent     Float? // used when the item's splitMode is 'percent'
  lineItem    ReceiptLineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)

  @@id([lineItemId, userId])
}

model ExchangeRate {
  id           String @id @default(cuid())
  date         String
  fromCurrency String
  toCurrency   String
  rate         Float

  @@unique([date, fromCurrency, toCurrency])
}
