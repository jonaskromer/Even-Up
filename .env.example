# Postgres
POSTGRES_PASSWORD=evenup_dev
DATABASE_URL=postgresql://evenup:evenup_dev@localhost:5432/evenup

# Supabase Auth (Cloud) — Settings → API in the Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co
# Public anon key — used server-side for auth REST calls (same value as VITE_SUPABASE_PUBLISHABLE_KEY)
SUPABASE_ANON_KEY=your-publishable-key
# Same project, used by the frontend (Vite inlines these at build time — see
# apps/web/Dockerfile and docker-compose.prod.yml's web.build.args)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# API server
PORT=4000

# Domain + HTTPS (used by Caddy; leave as "localhost" for local/CI — no TLS attempted)
DOMAIN=localhost

# Transactional emails (group invites, join-request notifications). If unset, these
# emails are silently skipped (dev/demo fallback). Get a key at https://resend.com
# after verifying your domain there. Signup/password-reset emails are sent by Supabase
# directly — see Authentication → Email Templates / SMTP Settings in its dashboard.
RESEND_API_KEY=
EMAIL_FROM=Even-Up <noreply@your-domain.com>
APP_URL=https://your-domain.com

# Receipt-upload AI parsing (Gemini). Optional — if unset, the "Add Receipt" feature
# is hidden and the app runs normally without it. Get a key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
